# API Configuration
# Note: For socket connection, the code strips /api/v1 from this URL
#
# Environment URLs:
# - Local Development: http://localhost:4003/api/v1
# - Dev Cloud: https://aim-coach-portal-api-dev-gmgjjvjmpq-nw.a.run.app/api/v1
# - Production: Configure via GitHub secret REACT_APP_API_URL_PROD
REACT_APP_API_URL=http://localhost:4003/api/v1

# Environment (development, staging, production)
REACT_APP_ENV=development

# Environment for frame/video URL paths (dev1, dev2, prod)
REACT_APP_ENVIRONMENT=dev2

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_GROUPS=true
REACT_APP_ENABLE_CHALLENGES=true

# Build Metadata (automatically set during CI/CD)
# REACT_APP_BUILD_TIME=[Set by build process]
# REACT_APP_GIT_SHA=[Set by build process]
